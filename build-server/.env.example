# AWS Configuration
AWS_REGION=<YOUR_AWS_REGION>
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>
S3_BUCKET_NAME=<YOUR_S3_BUCKET_NAME>

# Redis Configuration
REDIS_URL=<YOUR_REDIS_URL>
# Local: redis://localhost:6379
# Cloud (required for ECS): rediss://default:PASSWORD@HOST:PORT

# Project Configuration (injected by ECS at runtime - only needed for local testing)
GIT_REPOSITORY__URL=<GITHUB_REPO_URL>
PROJECT_ID=<PROJECT_SLUG>

# Note: When running in ECS, GIT_REPOSITORY__URL and PROJECT_ID 
# are automatically injected by the api-server via containerOverrides
