# AWS Configuration
AWS_REGION=<YOUR_AWS_REGION>
AWS_ACCESS_KEY_ID=<YOUR_AWS_ACCESS_KEY_ID>
AWS_SECRET_ACCESS_KEY=<YOUR_AWS_SECRET_ACCESS_KEY>

# ECS Configuration
ECS_CLUSTER_ARN=<YOUR_ECS_CLUSTER_ARN>
ECS_TASK_ARN=<YOUR_ECS_TASK_DEFINITION_ARN>
ECS_SUBNETS=<SUBNET_ID_1>,<SUBNET_ID_2>,<SUBNET_ID_3>
ECS_SECURITY_GROUPS=<SECURITY_GROUP_ID>

# Redis Configuration
REDIS_URL=<YOUR_REDIS_URL>
# Local: redis://localhost:6379
# Cloud: rediss://default:PASSWORD@HOST:PORT

# Server Configuration
PORT=9000
